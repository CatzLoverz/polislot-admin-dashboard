{
    frankenphp
    servers {
        timeouts {
            read_body 30s
            read_header 10s
            write 30s
            idle 120s
        }
    }
}

:80 {
    root * /var/www/html/public

    # Force HSTS header
    header Strict-Transport-Security "max-age=2592000; includeSubDomains;"

    # Reverse proxy WebSocket /app/* dan HTTP API /apps/* ke Reverb (internal port 8080)
    @websocket {
        path /app/* /apps/*
    }
    reverse_proxy @websocket 127.0.0.1:8080 {
        flush_interval -1
    }

    # Naikkan batas upload untuk frame video base64
    request_body {
        max_size 10MB
    }

    # Serve PHP untuk semua request lainnya
    php_server
}
