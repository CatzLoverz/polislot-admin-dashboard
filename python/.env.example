# ==========================================
# KONFIGURASI UMUM (YOLO & KAMERA)
# ==========================================
# Sumber video: "0" untuk webcam default, atau path video file / RTSP URL
CAMERA_SOURCE=0
# File weights model YOLOv8 (yolov8n.pt / custom model)
YOLO_WEIGHTS=yolov8n.pt
# Ambang batas kepercayaan YOLOv8 (0.0 s.d 1.0)
CONFIDENCE_THRESHOLD=0.4
# Filter index class YOLO: 2 = car (mobil), 3 = motorcycle (motor), pisahkan dengan koma tanpa spasi
TARGET_CLASSES=2,3
# Keamanan (Harus SAMA persis dengan IOT_API_SECRET di Laravel .env)
SHARED_SECRET=pOl1sL0t_ioT_s3creT_k3y_2026

# ==========================================
# KONFIGURASI MQTT (Hanya untuk skrip MQTT)
# ==========================================
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=polislot_user
MQTT_PASSWORD=secure_password

# ==========================================
# KONFIGURASI WEBSOCKET (Hanya untuk skrip WS)
# ==========================================
# Server Base URL (API endpoint HTTP POST)
SERVER_BASE_URL=http://127.0.0.1:8080
# Pengaturan Reverb WebSocket
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=ws
REVERB_APP_KEY=xcubvd4inm14ayepjhro
